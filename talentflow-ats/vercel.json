{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "EXPO_PUBLIC_API_URL": "https://talentlybackend-production.up.railway.app/api"
  },
  "envPrefix": "EXPO_",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
